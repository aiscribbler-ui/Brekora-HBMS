# Brekora BMS Environment Variables
# Copy this file to .env and fill in real values.

# Docker Compose
COMPOSE_PROJECT_NAME=brekora

# Application
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-32-byte-random-string
TOTP_ENCRYPTION_KEY=dev-totp-encryption-key-32-bytes

# PostgreSQL
POSTGRES_USER=brekora
POSTGRES_PASSWORD=brekora_dev_password
POSTGRES_DB=brekora
DATABASE_URL=postgresql+asyncpg://brekora:brekora_dev_password@db:5432/brekora

# Redis
REDIS_URL=redis://redis:6379/0

# Frontend
VITE_API_URL=http://localhost:8000
