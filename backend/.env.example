# Brekora BMS Environment Variables
# Copy this file to .env and fill in real values.

# Application
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-32-byte-random-string
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=brekora
POSTGRES_PASSWORD=brekora_dev_password
POSTGRES_DB=brekora
DATABASE_URL=postgresql+psycopg://brekora:brekora_dev_password@127.0.0.1:5433/brekora

# Redis
REDIS_URL=redis://127.0.0.1:6379/0

# Observability (leave empty to disable)
SENTRY_DSN=

# Gmail / Google OAuth (MVP: single Brekora mailbox)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/ota/gmail/callback
GOOGLE_ACCESS_TOKEN=
GOOGLE_REFRESH_TOKEN=
